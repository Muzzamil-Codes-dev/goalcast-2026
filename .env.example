# Copy to .env and fill in. All values have safe offline defaults.

# Database. Default = local SQLite (zero setup). For Postgres use docker compose:
# DATABASE_URL=postgresql+psycopg2://goalcast:goalcast@localhost:5432/goalcast
DATABASE_URL=sqlite:///data/goalcast.db

# MLflow. Default = local SQLite backend (no server needed; supports the registry).
MLFLOW_TRACKING_URI=sqlite:///mlflow.db
MODEL_NAME=goalcast-wdl

# LLM (AI Match Analyst). Leave blank to use the offline templated explainer.
ANTHROPIC_API_KEY=
LLM_MODEL=claude-haiku-4-5

# Live fixtures (optional). Leave USE_LIVE_API=false to run fully offline.
USE_LIVE_API=false
FOOTBALL_DATA_API_KEY=
